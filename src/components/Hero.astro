---

---

<section
  id="hero"
  class="min-h-[85vh] flex flex-col justify-center items-start relative pb-20"
>
  <div class="hero-content opacity-0">
    <div
      class="hero-badge inline-flex items-center gap-2 px-4 py-2 rounded-full border border-violet-500/30 bg-violet-500/10 text-violet-300 text-sm font-medium mb-8 backdrop-blur-md opacity-0 transform translate-y-4"
    >
      <span class="relative flex h-2.5 w-2.5">
        <span
          class="animate-ping absolute inline-flex h-full w-full rounded-full bg-violet-400 opacity-75"
        ></span>
        <span
          class="relative inline-flex rounded-full h-2.5 w-2.5 bg-violet-500"
        ></span>
      </span>
      Praca w Atipera
    </div>

    <h1
      class="text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight mb-6 leading-[1.1]"
    >
      <div class="hero-title-1 opacity-0 transform translate-y-4">
        Cześć, jestem
      </div>
      <span class="text-gradient inline-block pb-2 min-h-[1.2em] relative">
        <span class="hero-title-type"></span><span
          class="hero-cursor bg-cyan-400 w-[4px] h-[0.9em] inline-block ml-1 align-middle opacity-0"
        ></span>
      </span>
    </h1>

    <p
      class="hero-desc opacity-0 transform translate-y-4 text-lg md:text-xl text-zinc-400 max-w-2xl mb-12 leading-relaxed"
    >
      Tworzę nowoczesne, wydajne i estetyczne aplikacje internetowe z dbałością
      o każdy detal UI/UX. Specjalizuję się w innowacyjnych rozwiązaniach
      opartych na technologii Angular, Astro, React, Tailwind CSS i Kotlin.
    </p>

    <div
      class="flex flex-wrap gap-5 hero-buttons opacity-0 transform translate-y-4"
    >
      <a
        href="#contact"
        class="px-8 py-4 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-medium transition-all duration-300 shadow-[0_0_20px_rgba(139,92,246,0.3)] hover:shadow-[0_0_30px_rgba(139,92,246,0.5)] transform hover:-translate-y-1 flex items-center gap-2"
      >
        Skontaktuj się
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
            points="12 5 19 12 12 19"></polyline></svg
        >
      </a>
      <a
        href="#experience"
        class="px-8 py-4 rounded-xl glass hover:bg-white/10 text-zinc-300 font-medium transition-all duration-300 transform hover:-translate-y-1"
      >
        Moje doświadczenie
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { TextPlugin } from "gsap/TextPlugin";

  gsap.registerPlugin(TextPlugin);

  gsap.to(".hero-content", { opacity: 1, duration: 0.1 });

  const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

  gsap.to(".hero-cursor", {
    opacity: 1,
    repeat: -1,
    yoyo: true,
    duration: 0.5,
    ease: "steps(1)",
  });

  tl.to(".hero-badge", {
    y: 0,
    opacity: 1,
    duration: 0.8,
    delay: 0.2,
  })
    .to(
      ".hero-title-1",
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
      },
      "-=0.6",
    )
    .to(
      ".hero-title-type",
      {
        text: "Web Developerem",
        duration: 2,
        ease: "power1.inOut",
      },
      "-=0.2",
    )
    .to(
      ".hero-desc",
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
      },
      "-=0.5",
    )
    .to(
      ".hero-buttons",
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
      },
      "-=0.6",
    );
</script>
