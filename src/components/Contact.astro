---

---

<section id="contact" class="py-24 scroll-mt-20">
  <div
    class="flex items-center gap-6 mb-16 contact-header opacity-0 transform translate-y-8"
  >
    <h2 class="text-3xl md:text-5xl font-bold tracking-tight">Kontakt</h2>
    <div class="h-px bg-zinc-800 flex-grow max-w-xs"></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-12">
    <div class="flex flex-col justify-center">
      <h3
        class="contact-item opacity-0 transform translate-y-8 text-3xl md:text-4xl font-bold mb-6"
      >
        Porozmawiajmy o Twoim projekcie
      </h3>
      <p
        class="contact-item opacity-0 transform translate-y-8 text-zinc-400 text-lg leading-relaxed mb-10 max-w-md"
      >
        Niezależnie od tego, czy masz już gotowy pomysł, czy dopiero szukasz
        inspiracji – chętnie pomogę Ci stworzyć coś wyjątkowego, estetycznego i
        szybkiego.
      </p>

      <div class="space-y-6">
        <a
          href="mailto:shadowblack77.dev@gmail.com"
          class="contact-item opacity-0 transform translate-y-8 flex items-center gap-4 md:gap-5 text-zinc-300 hover:text-white transition-colors group p-4 -ml-4 rounded-2xl hover:bg-zinc-900/30 overflow-hidden"
        >
          <div
            class="w-14 h-14 shrink-0 rounded-full glass flex items-center justify-center group-hover:bg-violet-500/20 group-hover:border-violet-500/50 transition-colors shadow-lg"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-violet-400 group-hover:scale-110 transition-transform duration-300"
              ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
            >
          </div>
          <div class="min-w-0">
            <p class="text-sm text-zinc-500 mb-1">Napisz do mnie</p>
            <p class="font-medium text-base md:text-lg break-all">
              shadowblack77.dev@gmail.com
            </p>
          </div>
        </a>
        <a
          href="https://www.linkedin.com/in/daniel-miliczek-329521279"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-item opacity-0 transform translate-y-8 flex items-center gap-5 text-zinc-300 hover:text-white transition-colors group p-4 -ml-4 rounded-2xl hover:bg-zinc-900/30"
        >
          <div
            class="w-14 h-14 rounded-full glass flex items-center justify-center group-hover:bg-cyan-500/20 group-hover:border-cyan-500/50 transition-colors shadow-lg"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-cyan-400 group-hover:scale-110 transition-transform duration-300"
              ><path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path><rect width="4" height="12" x="2" y="9"></rect><circle
                cx="4"
                cy="4"
                r="2"></circle></svg
            >
          </div>
          <div>
            <p class="text-sm text-zinc-500 mb-1">Znajdź mnie na</p>
            <p class="font-medium text-lg">LinkedIn</p>
          </div>
        </a>

        <a
          href="https://github.com/ShadowBlack77"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-item opacity-0 transform translate-y-8 flex items-center gap-5 text-zinc-300 hover:text-white transition-colors group p-4 -ml-4 rounded-2xl hover:bg-zinc-900/30"
        >
          <div
            class="w-14 h-14 rounded-full glass flex items-center justify-center group-hover:bg-zinc-100/20 group-hover:border-zinc-100/50 transition-colors shadow-lg"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-zinc-300 group-hover:scale-110 transition-transform duration-300"
              ><path
                d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
              ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
            >
          </div>
          <div>
            <p class="text-sm text-zinc-500 mb-1">Zajrzyj na mój</p>
            <p class="font-medium text-lg">GitHub</p>
          </div>
        </a>
      </div>
    </div>

    <form
      id="contact-form"
      class="contact-form opacity-0 transform translate-y-8 glass-card p-8 md:p-10 flex flex-col gap-6 relative"
    >
      <input
        type="hidden"
        name="access_key"
        value="5d6599cc-96f2-4112-95ae-7fdf74b5f1d7"
      />
      <input
        type="checkbox"
        name="botcheck"
        class="hidden"
        style="display: none;"
      />

      <h4 class="text-2xl font-bold mb-2">Wyślij wiadomość</h4>

      <div class="flex flex-col gap-2 relative group">
        <label
          for="name"
          class="text-sm font-medium text-zinc-400 transition-colors group-focus-within:text-violet-400"
          >Imię i nazwisko</label
        >
        <input
          type="text"
          id="name"
          name="name"
          autocomplete="name"
          class="w-full bg-zinc-950/50 border border-white/10 rounded-xl px-4 py-3.5 text-white focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all placeholder:text-zinc-700"
          placeholder="Jan Kowalski"
          required
        />
      </div>

      <div class="flex flex-col gap-2 relative group">
        <label
          for="email"
          class="text-sm font-medium text-zinc-400 transition-colors group-focus-within:text-violet-400"
          >Adres e-mail</label
        >
        <input
          type="email"
          id="email"
          name="email"
          autocomplete="email"
          class="w-full bg-zinc-950/50 border border-white/10 rounded-xl px-4 py-3.5 text-white focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all placeholder:text-zinc-700"
          placeholder="jan@example.com"
          required
        />
      </div>

      <div class="flex flex-col gap-2 relative group">
        <label
          for="message"
          class="text-sm font-medium text-zinc-400 transition-colors group-focus-within:text-violet-400"
          >Wiadomość</label
        >
        <textarea
          id="message"
          name="message"
          rows="5"
          class="w-full bg-zinc-950/50 border border-white/10 rounded-xl px-4 py-3.5 text-white focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:border-violet-500/50 transition-all placeholder:text-zinc-700 resize-none"
          placeholder="Opisz swój projekt..."
          required></textarea>
      </div>

      <button
        type="submit"
        id="submit-button"
        class="w-full py-4 rounded-xl bg-gradient-to-r from-violet-600 to-cyan-600 hover:from-violet-500 hover:to-cyan-500 text-white font-bold text-lg transition-all duration-300 shadow-[0_0_20px_rgba(139,92,246,0.3)] hover:shadow-[0_0_30px_rgba(6,182,212,0.4)] transform hover:-translate-y-1 mt-4 relative overflow-hidden flex items-center justify-center gap-2"
      >
        <span id="submit-text">Wyślij</span>
        <svg
          id="submit-spinner"
          class="animate-spin -ml-1 mr-3 h-5 w-5 text-white hidden"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
        >
          <circle
            class="opacity-25"
            cx="12"
            cy="12"
            r="10"
            stroke="currentColor"
            stroke-width="4"></circle>
          <path
            class="opacity-75"
            fill="currentColor"
            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
          ></path>
        </svg>
      </button>

      <p
        id="form-result"
        class="text-center font-medium opacity-0 transition-opacity duration-300 absolute -bottom-10 left-0 right-0 text-sm"
      >
      </p>
    </form>
  </div>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#contact",
        start: "top 80%",
        once: true,
      },
    });

    tl.to(".contact-header", {
      y: 0,
      opacity: 1,
      duration: 0.8,
      ease: "power3.out",
    })
      .to(
        ".contact-item",
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          stagger: 0.15,
          ease: "power3.out",
        },
        "-=0.4",
      )
      .to(
        ".contact-form",
        {
          y: 0,
          opacity: 1,
          duration: 1,
          ease: "power3.out",
        },
        "-=0.8",
      );

    const form = document.getElementById("contact-form") as HTMLFormElement;
    const result = document.getElementById(
      "form-result",
    ) as HTMLParagraphElement;
    const submitText = document.getElementById(
      "submit-text",
    ) as HTMLSpanElement;
    const submitSpinner = document.getElementById(
      "submit-spinner",
    ) as HTMLElement;
    const submitButton = document.getElementById(
      "submit-button",
    ) as HTMLButtonElement;

    form.addEventListener("submit", function (e) {
      e.preventDefault();

      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      submitText.textContent = "Wysyłanie...";
      submitSpinner.classList.remove("hidden");
      submitButton.disabled = true;
      submitButton.classList.add("opacity-80", "cursor-not-allowed");
      result.classList.remove("opacity-100", "text-green-400", "text-red-400");
      result.classList.add("opacity-0");

      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: json,
      })
        .then(async (response) => {
          let json = await response.json();
          if (response.status == 200) {
            result.classList.add("text-green-400", "opacity-100");
            result.classList.remove("opacity-0");
            result.innerHTML = "Wiadomość wysłana pomyślnie!";
            form.reset();
          } else {
            console.log(response);
            result.classList.add("text-red-400", "opacity-100");
            result.classList.remove("opacity-0");
            result.innerHTML =
              json.message || "Coś poszło nie tak. Spróbuj ponownie.";
          }
        })
        .catch((error) => {
          console.log(error);
          result.classList.add("text-red-400", "opacity-100");
          result.classList.remove("opacity-0");
          result.innerHTML =
            "Wystąpił błąd krytyczny. Sprawdź połączenie z siecią.";
        })
        .then(function () {
          submitText.textContent = "Wyślij";
          submitSpinner.classList.add("hidden");
          submitButton.disabled = false;
          submitButton.classList.remove("opacity-80", "cursor-not-allowed");

          setTimeout(() => {
            result.classList.add("opacity-0");
            result.classList.remove("opacity-100");
          }, 5000);
        });
    });
  </script>
</section>
