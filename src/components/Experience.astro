---
const experiences = [
  {
    role: "Software Developer | Mid",
    company: "Atipera",
    period: "2025 - Obecnie",
    description:
      "Projektowanie i wdrażanie nowoczesnych interfejsów użytkownika, optymalizacja wydajności aplikacji webowych oraz mobilnych z wykorzystaniem Angular oaz Kotlin Multiplatform.",
  },
  {
    role: "Full-Stack Developer | Internship",
    company: "Lowgular",
    period: "Luty- Maj 2025",
    description:
      "Utrzymywanie oraz tworzenie funkcjonalności na platformie e-learningowej Lowgular z wykorzystaniem technolgoii Angular, NestJS oraz Firebase",
  },
  {
    role: "SQL Developer | Junior",
    company: "MMRC",
    period: "2023 - 2024",
    description:
      "Tworzenie aplikacji webowych w dziedzinie księgowości z wykorzystaniem języka T-SQL na platformie Archman Navigator",
  },
  {
    role: "IT Support | Mid",
    company: "AGMA Mysłowice",
    period: "2021 - 2023",
    description:
      "Zapewnienie wsparcia technicznego użytkownikom systemów informatycznych, rozwiązywanie problemów sprzętowych i programowych, administracja systemami oraz wdrażanie nowych rozwiązań IT",
  },
];
---

<section id="experience" class="py-24 scroll-mt-20">
  <div
    class="flex items-center gap-6 mb-16 exp-header opacity-0 transform translate-y-8"
  >
    <h2 class="text-3xl md:text-5xl font-bold tracking-tight">Doświadczenie</h2>
    <div class="h-px bg-zinc-800 flex-grow max-w-xs"></div>
  </div>

  <div class="relative ml-6 md:ml-0 md:space-y-12 space-y-8">
    <div
      class="md:hidden absolute top-0 bottom-0 left-[-1px] w-px bg-zinc-800 z-0"
    >
    </div>
    <div
      class="hidden md:block absolute top-0 bottom-0 left-[270px] w-px bg-zinc-800 z-0"
    >
    </div>

    {
      experiences.map((exp, index) => (
        <div class="relative pl-8 md:pl-0 exp-item opacity-0 transform translate-y-8 z-10">
          <div class="hidden md:block absolute left-[266px] top-[43px] w-2.5 h-2.5 rounded-full bg-violet-500 ring-4 ring-zinc-950 z-10" />
          <div class="flex flex-col md:flex-row gap-4 md:gap-10 items-start">
            <div class="md:w-[250px] md:shrink-0 md:text-right md:pt-[33px] mb-2 md:mb-0">
              <span class="text-sm font-semibold text-zinc-300 bg-zinc-900/60 px-4 py-1.5 rounded-full border border-white/5 inline-block backdrop-blur-sm shadow-sm md:w-auto break-words max-w-full">
                {exp.period}
              </span>
            </div>

            <div class="md:flex-1 w-full glass-card p-6 md:p-8 relative group hover:-translate-y-1 transition-all duration-300">
              <div class="md:hidden absolute left-[-37px] top-8 w-2.5 h-2.5 rounded-full bg-violet-500 ring-4 ring-zinc-950 z-10" />

              <div class="absolute inset-0 bg-gradient-to-r from-violet-500/5 to-cyan-500/5 opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl pointer-events-none" />

              <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-violet-400 transition-colors">
                {exp.role}
              </h3>
              <h4 class="text-zinc-400 font-medium mb-5 uppercase tracking-wide text-sm">
                {exp.company}
              </h4>
              <p class="text-zinc-400/90 leading-relaxed md:text-lg">
                {exp.description}
              </p>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: "#experience",
      start: "top 80%",
      once: true,
    },
  });

  tl.to(".exp-header", {
    y: 0,
    opacity: 1,
    duration: 0.8,
    ease: "power3.out",
  }).to(
    ".exp-item",
    {
      y: 0,
      opacity: 1,
      duration: 0.8,
      stagger: 0.2,
      ease: "power3.out",
    },
    "-=0.4",
  );
</script>
